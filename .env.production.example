POSTGRES_DB=muskit_platform
POSTGRES_USER=muskit
POSTGRES_PASSWORD=replace-with-a-long-random-password

ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

FRONTEND_URL=https://muskit.in
API_BASE_URL=https://muskit.in
CORS_ORIGINS=https://muskit.in,https://www.muskit.in,http://76.13.246.57

TRAEFIK_CERT_EMAIL=admin@muskit.in

EMAIL_PROVIDER=smtp
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=admin@muskit.in
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_NAME=Musk-IT

# Bounce handling: the SMTP relay has no bounce webhook, so non-delivery reports land
# back in this mailbox as regular email. IMAP_USER/IMAP_PASSWORD default to
# SMTP_USER/SMTP_PASSWORD above if left blank, since it's normally the same mailbox.
IMAP_HOST=imap.secureserver.net
IMAP_PORT=993
IMAP_SSL=true
IMAP_FOLDER=INBOX
IMAP_USER=
IMAP_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Shared HMAC secret for signed inbound integrations, incl. the ERP -> website
# purchase sync (POST /api/v1/public/erp/purchase). Generate with:
#   openssl rand -hex 32
# and set the SAME value as the ERP's WEBSITE_PURCHASE_SYNC_SECRET. If unset,
# inbound purchase syncs are rejected and ERP payments won't show in admin.
INTEGRATIONS_INBOUND_SECRET=
